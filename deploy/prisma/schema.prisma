// Prisma schema for PostgreSQL (Neon) — Vercel deployment
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("empleado")
  avatar    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships        ProjectMember[]
  companyMemberships CompanyMember[]
  employeeProgress   EmployeeProgress[]
  responsableZones   Zone[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  company     String
  companyId   String?
  startDate   DateTime @default(now())
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyRel         Company?            @relation(fields: [companyId], references: [id])
  zones              Zone[]
  members            ProjectMember[]
  progress           Progress[]
  employeeProgress   EmployeeProgress[]
  inventoryItems     InventoryItem[]
  examAnswers        ExamAnswer[]
  auditResults       AuditResult[]
  checklistResponses ChecklistResponse[]
  actionItems        ActionItem[]
  auditTargets       AuditTarget[]
  standards          Standard[]
  photos             PhotoLibrary[]
  pdcaItems          PDCAItem[]

  @@index([companyId])
}

model Zone {
  id              String   @id @default(cuid())
  name            String
  description     String?
  color           String   @default("#3B82F6")
  projectId       String
  responsableId   String?
  boardConfigId   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  responsable      User?               @relation(fields: [responsableId], references: [id], onDelete: SetNull)
  boardConfig      BoardConfiguration? @relation(fields: [boardConfigId], references: [id], onDelete: SetNull)
  memberZones      MemberZone[]
  actionItems      ActionItem[]
  progress         Progress[]
  employeeProgress EmployeeProgress[]
  inventoryItems   InventoryItem[]
  auditTargets     AuditTarget[]
  standards        Standard[]
  photos           PhotoLibrary[]
  pdcaItems        PDCAItem[]

  @@unique([name, projectId])
  @@index([projectId])
  @@index([responsableId])
  @@index([boardConfigId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  role      String
  joinedAt  DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zones   MemberZone[]

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model MemberZone {
  id         String   @id @default(cuid())
  memberId   String
  zoneId     String
  assignedAt DateTime @default(now())

  member ProjectMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  zone   Zone          @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([memberId, zoneId])
  @@index([memberId])
  @@index([zoneId])
}

model Progress {
  id        String    @id @default(cuid())
  sStep     Int
  miniStep  Int
  completed Boolean   @default(false)
  score     Float?
  notes     String?
  photoUrls String?
  passedAt  DateTime?
  projectId String
  zoneId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, zoneId])
}

model EmployeeProgress {
  id        String    @id @default(cuid())
  sStep     Int
  miniStep  Int
  completed Boolean   @default(false)
  score     Float?
  notes     String?
  passedAt  DateTime?
  projectId String
  zoneId    String
  userId    String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sStep, miniStep, projectId, zoneId, userId])
  @@index([projectId, zoneId])
  @@index([projectId, zoneId, userId])
}

model Template {
  id          String   @id @default(cuid())
  type        String
  sStep       Int
  miniStep    Int      @default(3)
  title       String
  description String?
  content     String
  notaMinima  Float?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slotTemplates BoardSlotTemplate[]
}

model ExamAnswer {
  id          String   @id @default(cuid())
  sStep       Int
  questionIdx Int
  answerIdx   Int
  correct     Boolean
  projectId   String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model InventoryItem {
  id                String    @id @default(cuid())
  sStep             Int
  name              String
  location          String?
  category          String
  quantity          Int       @default(1)
  quantityNeeded    Int       @default(0)
  quantityUnneeded  Int       @default(0)
  price             Float?
  action            String?
  photoUrl          String?
  extra             String?
  projectId         String
  zoneId            String?
  jaulaStatus       String    @default("")
  jaulaFechaEntrada DateTime?
  jaulaOrigen       String?
  jaulaFechaSalida  DateTime?
  jaulaDestino      String?
  zonaOrigen        String?
  zonaDestino       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([sStep, projectId])
  @@index([jaulaStatus])
  @@index([zoneId])
}

model AuditResult {
  id            String   @id @default(cuid())
  sStep         Int
  auditorName   String
  result        String
  score         Float?
  observations  String?
  auditType     String   @default("quarterly")
  checklistData String?
  mejorasData   String?
  auditDate     DateTime @default(now())
  projectId     String
  createdAt     DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([auditType])
}

model ChecklistResponse {
  id            String   @id @default(cuid())
  sStep         Int
  miniStep      Int
  results       String
  completed     Boolean  @default(false)
  score         Float
  observaciones String?
  auditor       String?
  projectId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ActionItem {
  id              String    @id @default(cuid())
  sStep           Int
  miniStep        Int
  itemId          String
  itemDescription String
  hallazgo        String
  mejora          String?
  responsable     String?
  prioridad       String    @default("media")
  estado          String    @default("abierta")
  fechaCompromiso DateTime?
  fechaLimite     DateTime?
  fechaReal       DateTime?
  fechaResolucion DateTime?
  photoRefs       String?
  notas           String?
  source          String    @default("autoevaluacion")
  auditor         String?
  zoneId          String?
  verificadoPor   String?
  projectId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  numeroEntrada       Int?
  fechaEntrada        DateTime?
  comunicadoPor       String?
  semana              String?
  seccionDemandante   String?
  clienteZona         String?
  personaDemandada    String?
  seccionDemandada    String?
  impactoObjetivo     String?
  enviado             String?
  accionCorrectiva    String?
  accionesPreventivas String?
  semanaPrevista      String?
  porcentaje          Float?    @default(0)
  semanaReal          String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([zoneId])
}

model AuditTarget {
  id         String   @id @default(cuid())
  projectId  String
  sStep      Int
  miniStep   Int      @default(4)
  zoneId     String?
  notaMinima Float    @default(70)
  objetivo   Float    @default(80)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([projectId, sStep, miniStep, zoneId])
  @@index([projectId])
}

model RolePermissionConfig {
  id         String   @id @default(cuid())
  role       String
  permission String
  allowed    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([role, permission])
}

model Company {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
  members  CompanyMember[]
}

model CompanyMember {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      String   @default("gerente")
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model Standard {
  id             String   @id @default(cuid())
  sStep          Int
  title          String
  description    String?
  category       String  @default("general")
  content        String?
  photoUrl       String?
  beforePhotoUrl String?
  afterPhotoUrl  String?
  responsable    String?
  contacto       String?
  mejoraTipo     String?
  status         String  @default("activo")
  version        Int      @default(1)
  projectId      String
  zoneId         String?
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  slotStandards BoardSlotStandard[]

  @@index([projectId])
  @@index([sStep, projectId])
  @@index([category])
}

model BoardConfiguration {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slots BoardSlot[]
  zones Zone[]
}

model BoardSlot {
  id            String   @id @default(cuid())
  boardConfigId String
  sStep         Int
  miniStep      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  boardConfig BoardConfiguration @relation(fields: [boardConfigId], references: [id], onDelete: Cascade)
  templates   BoardSlotTemplate[]
  standards   BoardSlotStandard[]

  @@unique([boardConfigId, sStep, miniStep])
  @@index([boardConfigId])
}

model BoardSlotTemplate {
  id          String   @id @default(cuid())
  slotId      String
  templateId  String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  slot     BoardSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  template Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([slotId, templateId])
  @@index([slotId])
  @@index([templateId])
}

model BoardSlotStandard {
  id          String   @id @default(cuid())
  slotId      String
  standardId  String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  slot     BoardSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  standard Standard  @relation(fields: [standardId], references: [id], onDelete: Cascade)

  @@unique([slotId, standardId])
  @@index([slotId])
  @@index([standardId])
}

model PhotoLibrary {
  id          String   @id @default(cuid())
  sStep       Int
  miniStep    Int      @default(2)
  title       String
  description String?
  photoUrl    String
  photoType   String  @default("antes")
  category    String  @default("general")
  tags        String?
  projectId   String
  zoneId      String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([sStep, projectId])
  @@index([photoType])
}

model PDCAItem {
  id           String   @id @default(cuid())
  title        String
  description  String?
  phase        String   @default("plan")
  sStep        Int      @default(1)
  responsable  String?
  prioridad    String   @default("media")
  estado       String   @default("pendiente")
  fechaInicio  DateTime @default(now())
  fechaLimite  DateTime?
  resultado    String?
  projectId    String
  zoneId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone    Zone?   @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([phase])
  @@index([estado])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  sStep     Int?
  zoneId    String?
  projectId String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([projectId])
}
