// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  name        String
  password    String
  role        String          @default("empleado") // "admin", "responsable", "empleado", "auditor"
  avatar      String?
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  memberships ProjectMember[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  company     String
  startDate   DateTime @default(now())
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zones              Zone[]
  members            ProjectMember[]
  progress           Progress[]
  inventoryItems     InventoryItem[]
  examAnswers        ExamAnswer[]
  auditResults       AuditResult[]
  checklistResponses ChecklistResponse[]
  actionItems        ActionItem[]
}

model Zone {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#3B82F6")
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members     ProjectMember[]

  @@unique([name, projectId])
  @@index([projectId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  zoneId    String?
  role      String // "admin", "responsable", "empleado", "auditor"
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  zone      Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model Progress {
  id          String    @id @default(cuid())
  sStep       Int       // 1-5 (Revisar, Ordenar, Limpiar, Estandarizar, Mantener)
  miniStep    Int       // 1-5 (Formación, Fotos, Inventario, Autoevaluación, Auditoría)
  completed   Boolean   @default(false)
  score       Float?    // Puntuación obtenida (0-100)
  notes       String?   // Notas adicionales
  photoUrls   String?   // URLs de fotos (JSON array o separadas por coma)
  passedAt    DateTime? // Fecha en que se pasó el mini-paso
  projectId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([sStep, miniStep, projectId])
  @@index([projectId])
}

model Template {
  id          String   @id @default(cuid())
  type        String   // "formacion", "examen", "inventario", "autoevaluacion", "auditoria"
  sStep       Int      // 1-5
  title       String
  description String?
  content     String   // JSON con el contenido de la plantilla
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExamAnswer {
  id          String   @id @default(cuid())
  sStep       Int
  questionIdx Int
  answerIdx   Int
  correct     Boolean
  projectId   String
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model InventoryItem {
  id          String   @id @default(cuid())
  sStep       Int
  name        String
  location    String?
  category    String   // "util", "innecesario", "dudoso"
  quantity    Int      @default(1)
  action      String?  // Acción a tomar
  photoUrl    String?
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AuditResult {
  id           String   @id @default(cuid())
  sStep        Int
  auditorName  String
  result       String   // "apto", "no_apto"
  score        Float?
  observations String?
  auditDate    DateTime @default(now())
  projectId    String
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ChecklistResponse {
  id            String   @id @default(cuid())
  sStep         Int      // 1-5
  miniStep      Int      // 4 (autoevaluacion) or 5 (auditoria)
  results       String   // JSON: { itemId: { status, hallazgo, mejora, otherText, photoRefs } }
  completed     Boolean  @default(false)
  score         Float    // 0-100
  observaciones String?
  auditor       String?  // Nombre del auditor (solo para paso 5)
  projectId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ActionItem {
  id              String    @id @default(cuid())
  sStep           Int       // 1-5
  miniStep        Int       // 4 (autoevaluacion) or 5 (auditoria)
  itemId          String    // e.g. "1.2.3"
  itemDescription String    // Checklist item description
  hallazgo        String    // Descripción de la desviación detectada
  mejora          String?   // Sugerencia de mejora / plan de acción
  responsable     String?   // Persona responsable de resolver
  prioridad       String    @default("media") // "alta", "media", "baja"
  estado          String    @default("abierta") // "abierta", "en_proceso", "resuelta", "cerrada"
  fechaLimite     DateTime?
  fechaResolucion DateTime?
  photoRefs       String?   // JSON array of photo references
  notas           String?   // Notas adicionales sobre la resolución
  source          String    @default("autoevaluacion") // "autoevaluacion" or "auditoria"
  auditor         String?   // Nombre del auditor que detectó la deficiencia
  projectId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model RolePermissionConfig {
  id           String   @id @default(cuid())
  role         String   // "admin", "responsable", "empleado", "auditor"
  permission   String   // e.g. "view_board", "complete_steps", etc.
  allowed      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([role, permission])
}
